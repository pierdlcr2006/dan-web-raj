---
import SiteNav from "../components/SiteNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { courseStats, student, weeks } from "../data/weeks";

const firstWeek = weeks[0];
---

<BaseLayout
  title={`${student.course} | ${student.name}`}
  description={`Presentación del curso ${student.course} con documentos por semana.`}
>
  <header class="relative overflow-hidden bg-ivory">
    <SiteNav />

    <section class="hero-shell mx-auto grid min-h-[88vh] max-w-7xl items-center gap-10 px-5 pb-16 pt-28 sm:px-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,440px)]">
      <div class="relative z-10 max-w-3xl">
        <h1 class="reveal mt-5 max-w-5xl text-4xl font-semibold leading-[1.04] text-ink sm:text-6xl lg:text-7xl">
          Razonamiento y argumentación jurídica
        </h1>
        <p class="reveal mt-6 max-w-2xl text-lg leading-8 text-ink/72">
          Presentación organizada por semanas. Cada semana muestra dos PDF:
          el PPT del profesor y el trabajo realizado.
        </p>

        <div class="reveal mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href={`/semana/${firstWeek.slug}/`}>Explorar semanas</a>
          <a class="button-ghost" href={`/semana/${firstWeek.slug}/`}>Ver semana 1</a>
        </div>

        <dl class="reveal mt-10 grid max-w-2xl grid-cols-1 gap-3 sm:grid-cols-3">
          {courseStats.map((stat) => (
            <div class="stat-tile">
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <aside class="reveal profile-frame course-cover" aria-label="Perfil de estudiante">
        <div class="hero-portrait">
          <img src={student.profileImage} alt="Espacio para foto de Daniela Ariana Valer Alfaro" loading="eager" />
        </div>
        <div class="mt-6">
          <p class="eyebrow">Presentado por</p>
          <h2 class="mt-3 text-3xl font-semibold leading-tight text-ink">{student.name}</h2>
        </div>
      </aside>
    </section>

    <img
      class="hero-visual"
      src="/images/legal-study-hero.png"
      alt="Mesa de estudio jurídico con documentos"
      loading="eager"
    />
  </header>

  <main>
    <section class="section-band bg-white">
      <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
        <div class="home-overview">
          <article class="reveal overview-lead">
            <p class="eyebrow">Panel del curso</p>
            <h2>Una lectura clara para cada semana</h2>
            <p>
              El sitio funciona como un expediente académico: primero ubicas la semana,
              luego revisas el material del profesor y después el trabajo realizado.
            </p>
          </article>

          <div class="reveal overview-steps" aria-label="Flujo de revisión">
            <div>
              <span>01</span>
              <strong>Elegir semana</strong>
              <p>Acceso directo desde el índice compacto.</p>
            </div>
            <div>
              <span>02</span>
              <strong>Revisar PPT</strong>
              <p>Ventana PDF del material del profesor.</p>
            </div>
            <div>
              <span>03</span>
              <strong>Comparar trabajo</strong>
              <p>Segunda ventana con lo realizado.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="mx-auto flex max-w-7xl flex-col gap-3 px-5 py-8 sm:flex-row sm:items-center sm:justify-between sm:px-8">
      <p>2026 · {student.name}</p>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/daniela-v-b59386336/" target="_blank" rel="noreferrer" aria-label="LinkedIn de Daniela Ariana Valer Alfaro">
          <img src="/images/linkedin.svg" alt="" aria-hidden="true" />
        </a>
        <p>Creado en colaboracion con PF</p>
      </div>
    </div>
  </footer>
</BaseLayout>
