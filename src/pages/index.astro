---
import BaseLayout from "../layouts/BaseLayout.astro";
import { areas, courseStats, learningRoute, student, weeks } from "../data/weeks";

const firstWeek = weeks[0];
---

<BaseLayout
  title={`${student.course} | ${student.name}`}
  description={`Presentación interactiva del curso ${student.course} desarrollada para ${student.name}.`}
>
  <header class="relative overflow-hidden bg-ivory">
    <nav class="fixed left-0 right-0 top-0 z-40 border-b border-ink/10 bg-ivory/88 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
        <a href="/" class="text-sm font-semibold uppercase text-burgundy">Argumentación jurídica</a>
        <div class="hidden items-center gap-6 text-sm font-medium text-ink/70 md:flex">
          <a class="nav-link" href="#ruta">Ruta</a>
          <a class="nav-link" href="#semanas">Semanas</a>
          <a class="nav-link" href="#metodo">Método</a>
        </div>
        <a class="button-secondary" href={`/semana/${firstWeek.slug}/`}>Empezar</a>
      </div>
    </nav>

    <section class="hero-shell mx-auto grid min-h-[92vh] max-w-7xl items-center gap-10 px-5 pb-16 pt-28 sm:px-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,440px)]">
      <div class="relative z-10 max-w-3xl">
        <p class="reveal eyebrow">Curso de Derecho</p>
        <h1 class="reveal mt-5 max-w-5xl text-5xl font-semibold leading-[1.02] text-ink sm:text-6xl lg:text-7xl">
          Razonamiento y argumentación jurídica
        </h1>
        <p class="reveal mt-6 max-w-2xl text-lg leading-8 text-ink/72">
          Una presentación interactiva para organizar 16 semanas de análisis jurídico,
          construcción de tesis, interpretación normativa, prueba y defensa argumentativa.
        </p>

        <div class="reveal mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href="#semanas">Explorar semanas</a>
          <a class="button-ghost" href={`/semana/${firstWeek.slug}/`}>Ver semana 1</a>
        </div>

        <dl class="reveal mt-10 grid max-w-2xl grid-cols-1 gap-3 sm:grid-cols-3">
          {courseStats.map((stat) => (
            <div class="stat-tile">
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <aside class="reveal profile-frame" aria-label="Perfil de estudiante">
        <div class="hero-portrait">
          <img src={student.profileImage} alt="Espacio para foto de Daniela Ariana Valer Alfaro" loading="eager" />
        </div>
        <div class="mt-6">
          <p class="eyebrow">Presentado por</p>
          <h2 class="mt-3 text-3xl font-semibold leading-tight text-ink">{student.name}</h2>
          <p class="mt-4 text-sm leading-6 text-ink/70">
            Estudiante de Derecho. Espacio preparado para incorporar su fotografía y los trabajos reales de cada semana.
          </p>
        </div>
      </aside>
    </section>

    <img
      class="hero-visual"
      src="/images/legal-study-hero.png"
      alt="Mesa de estudio jurídico con libros, expediente y luz cálida"
      loading="eager"
    />
  </header>

  <main>
    <section id="ruta" class="section-band bg-white">
      <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
        <div class="reveal max-w-3xl">
          <p class="eyebrow">Ruta de aprendizaje</p>
          <h2 class="section-title mt-4">Del caso a la defensa jurídica</h2>
          <p class="mt-5 text-lg leading-8 text-ink/70">
            La experiencia está pensada como una carpeta viva de trabajo: cada semana aporta una pieza para razonar mejor,
            escribir con orden y defender una postura jurídica con criterio.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-4">
          {learningRoute.map((item, index) => (
            <article class="reveal route-card" style={`--delay: ${index * 90}ms`}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="semanas" class="section-band bg-parchment">
      <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div class="reveal max-w-3xl">
            <p class="eyebrow">Mapa semanal</p>
            <h2 class="section-title mt-4">16 semanas navegables, no diapositivas sueltas</h2>
            <p class="mt-5 text-lg leading-8 text-ink/70">
              Cada bloque tiene pregunta guía, competencias, actividades y entregable. Puedes filtrar por área o buscar
              una semana concreta.
            </p>
          </div>

          <div class="reveal week-tools" aria-label="Filtros de semanas">
            <label class="sr-only" for="week-search">Buscar semana</label>
            <input id="week-search" data-week-search type="search" placeholder="Buscar tema, semana o actividad" />
            <div class="area-filters">
              <button type="button" data-area-filter="Todas" aria-pressed="true">Todas</button>
              {areas.map((area) => (
                <button type="button" data-area-filter={area} aria-pressed="false">{area}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {weeks.map((week) => (
            <a
              class="reveal week-card"
              href={`/semana/${week.slug}/`}
              data-week-card
              data-area={week.area}
              data-title={week.title}
              data-summary={week.summary}
            >
              <span class="week-chip">Semana {week.number}</span>
              <p class="mt-5 text-xs font-semibold uppercase text-teal">{week.area}</p>
              <h3 class="mt-3 text-xl font-semibold leading-snug text-ink">{week.title}</h3>
              <p class="mt-4 text-sm leading-6 text-ink/66">{week.summary}</p>
              <span class="mt-6 inline-flex text-sm font-semibold text-burgundy">Abrir expediente</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="metodo" class="section-band bg-ink text-white">
      <div class="mx-auto grid max-w-7xl gap-10 px-5 py-20 sm:px-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="reveal">
          <p class="eyebrow text-gold">Método de trabajo</p>
          <h2 class="section-title mt-4 text-white">Una presentación con lógica de expediente</h2>
          <p class="mt-5 text-lg leading-8 text-white/72">
            La navegación está organizada para revisar el curso como una secuencia de decisiones: problema jurídico,
            tesis, razones, prueba, objeciones y cierre.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <article class="reveal method-card">
            <h3>Lectura activa</h3>
            <p>Permite ordenar hechos y conceptos antes de escoger una posición jurídica.</p>
          </article>
          <article class="reveal method-card">
            <h3>Argumentos trazables</h3>
            <p>Cada idea queda conectada a normas, principios, precedentes o prueba.</p>
          </article>
          <article class="reveal method-card">
            <h3>Defensa oral</h3>
            <p>La ruta ayuda a pasar del texto jurídico a una exposición clara y persuasiva.</p>
          </article>
          <article class="reveal method-card">
            <h3>Actualizable</h3>
            <p>Cuando lleguen los trabajos reales, se reemplaza el contenido en un solo archivo de datos.</p>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
