---
import BaseLayout from "../layouts/BaseLayout.astro";
import { courseStats, student, weeks } from "../data/weeks";

const firstWeek = weeks[0];
---

<BaseLayout
  title={`${student.course} | ${student.name}`}
  description={`Presentación del curso ${student.course} con documentos por semana.`}
>
  <header class="relative overflow-hidden bg-ivory">
    <nav class="fixed left-0 right-0 top-0 z-40 border-b border-ink/10 bg-ivory/88 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
        <a href="/" class="text-sm font-semibold uppercase text-burgundy">Argumentación jurídica</a>
        <div class="hidden items-center gap-6 text-sm font-medium text-ink/70 md:flex">
          <a class="nav-link" href="#semanas">Semanas</a>
          <a class="nav-link" href="#documentos">Documentos</a>
        </div>
        <a class="button-secondary" href={`/semana/${firstWeek.slug}/`}>Empezar</a>
      </div>
    </nav>

    <section class="hero-shell mx-auto grid min-h-[88vh] max-w-7xl items-center gap-10 px-5 pb-16 pt-28 sm:px-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,440px)]">
      <div class="relative z-10 max-w-3xl">
        <p class="reveal eyebrow">Curso de Derecho</p>
        <h1 class="reveal mt-5 max-w-5xl text-4xl font-semibold leading-[1.04] text-ink sm:text-6xl lg:text-7xl">
          Razonamiento y argumentación jurídica
        </h1>
        <p class="reveal mt-6 max-w-2xl text-lg leading-8 text-ink/72">
          Presentación organizada por semanas. Cada semana muestra dos PDF:
          el PPT del profesor y el trabajo realizado.
        </p>

        <div class="reveal mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href="#semanas">Explorar semanas</a>
          <a class="button-ghost" href={`/semana/${firstWeek.slug}/`}>Ver semana 1</a>
        </div>

        <dl class="reveal mt-10 grid max-w-2xl grid-cols-1 gap-3 sm:grid-cols-3">
          {courseStats.map((stat) => (
            <div class="stat-tile">
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <aside class="reveal profile-frame" aria-label="Perfil de estudiante">
        <div class="hero-portrait">
          <img src={student.profileImage} alt="Espacio para foto de Daniela Ariana Valer Alfaro" loading="eager" />
        </div>
        <div class="mt-6">
          <p class="eyebrow">Presentado por</p>
          <h2 class="mt-3 text-3xl font-semibold leading-tight text-ink">{student.name}</h2>
          <p class="mt-4 text-sm leading-6 text-ink/70">
            Espacio preparado para incorporar su foto y revisar los documentos de cada semana.
          </p>
        </div>
      </aside>
    </section>

    <img
      class="hero-visual"
      src="/images/legal-study-hero.png"
      alt="Mesa de estudio jurídico con documentos"
      loading="eager"
    />
  </header>

  <main>
    <section id="semanas" class="section-band bg-parchment">
      <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div class="reveal max-w-3xl">
            <p class="eyebrow">Mapa semanal</p>
            <h2 class="section-title mt-4">16 carpetas, dos documentos por semana</h2>
            <p class="mt-5 text-lg leading-8 text-ink/70">
              Sube cada PDF en su carpeta correspondiente. El visor los mostrará dentro de una ventana propia,
              sin usar el visor clásico del navegador.
            </p>
          </div>

          <div class="reveal week-tools" aria-label="Buscar semanas">
            <label class="sr-only" for="week-search">Buscar semana</label>
            <input id="week-search" data-week-search type="search" placeholder="Buscar semana o carpeta" />
          </div>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {weeks.map((week) => (
            <a
              class="reveal week-card"
              href={`/semana/${week.slug}/`}
              data-week-card
              data-title={week.title}
              data-summary={`${week.folder} ppt-profesor.pdf trabajo.pdf`}
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="week-chip">{week.title}</span>
                <span class="content-status is-ready">{week.folder}</span>
              </div>
              <h3 class="mt-5 text-xl font-semibold leading-snug text-ink">PPT profesor + trabajo</h3>
              <p class="mt-4 text-sm leading-6 text-ink/66">
                Carpeta: public/documentos/{week.folder}
              </p>
              <div class="mt-auto flex flex-wrap gap-2 pt-6">
                <span class="mini-tag">ppt-profesor.pdf</span>
                <span class="mini-tag">trabajo.pdf</span>
              </div>
              <span class="mt-5 inline-flex text-sm font-semibold text-burgundy">Abrir visor</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="documentos" class="section-band bg-ink text-white">
      <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
        <div class="reveal max-w-3xl">
          <p class="eyebrow text-gold">Estructura de archivos</p>
          <h2 class="section-title mt-4 text-white">Sube los PDF sin cambiar el código</h2>
          <p class="mt-5 text-lg leading-8 text-white/72">
            Para cada semana usa la misma convención:
            <code class="inline-code">ppt-profesor.pdf</code> y <code class="inline-code">trabajo.pdf</code>.
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
