---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { student, weeks, type Week } from "../../data/weeks";

export function getStaticPaths() {
  return weeks.map((week, index) => ({
    params: { slug: week.slug },
    props: { week, index },
  }));
}

type Props = {
  week: Week;
  index: number;
};

const { week, index } = Astro.props;
const previous = weeks[index - 1];
const next = weeks[index + 1];
const progress = Math.round((week.number / weeks.length) * 100);
---

<BaseLayout
  title={`Semana ${week.number}: ${week.title} | ${student.course}`}
  description={week.summary}
>
  <header class="bg-ivory">
    <nav class="fixed left-0 right-0 top-0 z-40 border-b border-ink/10 bg-ivory/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
        <a href="/" class="text-sm font-semibold uppercase text-burgundy">Volver al mapa</a>
        <a class="button-secondary" href="/#semanas">Todas las semanas</a>
      </div>
    </nav>

    <section class="mx-auto max-w-7xl px-5 pb-12 pt-28 sm:px-8">
      <div class="reveal max-w-4xl">
        <p class="eyebrow">Semana {week.number} de {weeks.length}</p>
        <h1 class="mt-5 text-4xl font-semibold leading-tight text-ink sm:text-6xl">{week.title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-ink/70">{week.summary}</p>
      </div>
      <div class="reveal mt-10 overflow-hidden rounded bg-white shadow-soft">
        <div class="flex items-center justify-between px-5 py-4 text-sm font-semibold text-ink/70">
          <span>Progreso del curso</span>
          <span>{progress}%</span>
        </div>
        <div class="h-2 bg-ink/10">
          <div class="h-full bg-burgundy" style={`width: ${progress}%`}></div>
        </div>
      </div>
    </section>
  </header>

  <main class="bg-white">
    <div class="mx-auto grid max-w-7xl gap-8 px-5 py-16 sm:px-8 lg:grid-cols-[280px_minmax(0,1fr)]">
      <aside class="weekly-sidebar reveal">
        <p class="text-xs font-semibold uppercase text-ink/45">Índice del curso</p>
        <nav class="mt-4 grid gap-2" aria-label="Navegación por semanas">
          {weeks.map((item) => (
            <a
              class:list={[
                "sidebar-week",
                item.slug === week.slug && "is-active",
              ]}
              href={`/semana/${item.slug}/`}
            >
              <span>{String(item.number).padStart(2, "0")}</span>
              <strong>{item.title}</strong>
            </a>
          ))}
        </nav>
      </aside>

      <article class="space-y-6">
        <section class="reveal dossier-panel">
          <p class="eyebrow">Pregunta guía</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-ink">{week.guidingQuestion}</h2>
        </section>

        <section class="grid gap-6 xl:grid-cols-[1fr_0.85fr]">
          <div class="reveal dossier-panel">
            <div class="flex items-center justify-between gap-4">
              <p class="eyebrow">Competencias</p>
              <span class="area-pill">{week.area}</span>
            </div>
            <ul class="mt-6 grid gap-3">
              {week.competencies.map((competency) => (
                <li class="check-item">{competency}</li>
              ))}
            </ul>
          </div>

          <div class="reveal dossier-panel">
            <p class="eyebrow">Producto de la semana</p>
            <h2 class="mt-4 text-2xl font-semibold leading-tight text-ink">{week.deliverable}</h2>
            <p class="mt-5 text-sm leading-6 text-ink/68">{week.evidence}</p>
          </div>
        </section>

        <section class="reveal dossier-panel">
          <p class="eyebrow">Actividades sugeridas</p>
          <div class="mt-6 grid gap-4 md:grid-cols-3">
            {week.activities.map((activity, activityIndex) => (
              <article class="activity-block">
                <span>{String(activityIndex + 1).padStart(2, "0")}</span>
                <p>{activity}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="reveal argument-map">
          <div>
            <p class="eyebrow">Estructura argumentativa</p>
            <h2>Cómo se conecta esta semana con el expediente final</h2>
          </div>
          <div class="argument-grid">
            <div>
              <span>Problema</span>
              <p>Delimitar la pregunta jurídica que debe resolverse.</p>
            </div>
            <div>
              <span>Tesis</span>
              <p>Plantear una respuesta defendible frente a objeciones.</p>
            </div>
            <div>
              <span>Razones</span>
              <p>Sostener la tesis con norma, principios, prueba y precedentes.</p>
            </div>
            <div>
              <span>Cierre</span>
              <p>Mostrar por qué la solución propuesta es la más razonable.</p>
            </div>
          </div>
        </section>

        <nav class="reveal week-pagination" aria-label="Semana anterior y siguiente">
          {previous ? (
            <a href={`/semana/${previous.slug}/`}>
              <span>Anterior</span>
              <strong>Semana {previous.number}: {previous.title}</strong>
            </a>
          ) : (
            <a href="/">
              <span>Inicio</span>
              <strong>Mapa general del curso</strong>
            </a>
          )}

          {next ? (
            <a href={`/semana/${next.slug}/`}>
              <span>Siguiente</span>
              <strong>Semana {next.number}: {next.title}</strong>
            </a>
          ) : (
            <a href="/">
              <span>Cierre</span>
              <strong>Volver al mapa general</strong>
            </a>
          )}
        </nav>
      </article>
    </div>
  </main>
</BaseLayout>
