---
import PdfWindow from "../../components/PdfWindow.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { student, weeks, type Week } from "../../data/weeks";

export function getStaticPaths() {
  return weeks.map((week, index) => ({
    params: { slug: week.slug },
    props: { week, index },
  }));
}

type Props = {
  week: Week;
  index: number;
};

const { week, index } = Astro.props;
const previous = weeks[index - 1];
const next = weeks[index + 1];
---

<BaseLayout
  title={`${week.title} | ${student.course}`}
  description={`Documentos de ${week.title}: PPT del profesor y trabajo realizado.`}
>
  <header class="bg-ivory">
    <nav class="fixed left-0 right-0 top-0 z-40 border-b border-ink/10 bg-ivory/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
        <a href="/" class="text-sm font-semibold uppercase text-burgundy">Volver al mapa</a>
        <a class="button-secondary" href="/#semanas">Todas las semanas</a>
      </div>
    </nav>

    <section class="week-hero mx-auto max-w-7xl px-5 pb-12 pt-28 sm:px-8">
      <div class="reveal max-w-4xl">
        <p class="eyebrow">Carpeta {week.folder}</p>
        <h1>{week.title}</h1>
        <p>
          Esta semana muestra dos documentos: el PPT del profesor y el trabajo realizado.
          Sube los archivos PDF en la carpeta indicada y el visor los cargará automáticamente.
        </p>
      </div>
    </section>
  </header>

  <main class="bg-white">
    <div class="mx-auto grid max-w-7xl gap-8 px-5 py-12 sm:px-8 lg:grid-cols-[240px_minmax(0,1fr)]">
      <aside class="weekly-sidebar reveal">
        <p class="text-xs font-semibold uppercase text-ink/45">Semanas</p>
        <nav class="mt-4 grid gap-2" aria-label="Navegación por semanas">
          {weeks.map((item) => (
            <a
              class:list={[
                "sidebar-week",
                item.slug === week.slug && "is-active",
              ]}
              href={`/semana/${item.slug}/`}
            >
              <span>{String(item.number).padStart(2, "0")}</span>
              <strong>{item.title}</strong>
            </a>
          ))}
        </nav>
      </aside>

      <article class="document-workspace">
        <section class="document-grid" aria-label={`Documentos de ${week.title}`}>
          {week.documents.map((document) => (
            <PdfWindow document={document} />
          ))}
        </section>

        <nav class="reveal week-pagination" aria-label="Semana anterior y siguiente">
          {previous ? (
            <a href={`/semana/${previous.slug}/`}>
              <span>Anterior</span>
              <strong>{previous.title}</strong>
            </a>
          ) : (
            <a href="/">
              <span>Inicio</span>
              <strong>Mapa general del curso</strong>
            </a>
          )}

          {next ? (
            <a href={`/semana/${next.slug}/`}>
              <span>Siguiente</span>
              <strong>{next.title}</strong>
            </a>
          ) : (
            <a href="/">
              <span>Cierre</span>
              <strong>Volver al mapa general</strong>
            </a>
          )}
        </nav>
      </article>
    </div>
  </main>
</BaseLayout>
