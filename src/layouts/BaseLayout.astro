---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Razonamiento y argumentación jurídica",
  description = "Presentación interactiva del curso de Razonamiento y argumentación jurídica.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      const revealNodes = document.querySelectorAll(".reveal");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16 },
        );

        revealNodes.forEach((node) => observer.observe(node));
      } else {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
      }

      const weekSearch = document.querySelector("[data-week-search]");
      const areaButtons = document.querySelectorAll("[data-area-filter]");
      const weekCards = document.querySelectorAll("[data-week-card]");
      let activeArea = "Todas";

      const filterWeeks = () => {
        const query = weekSearch?.value?.toLowerCase().trim() ?? "";

        weekCards.forEach((card) => {
          const matchesArea = activeArea === "Todas" || card.dataset.area === activeArea;
          const text = `${card.dataset.title} ${card.dataset.summary}`.toLowerCase();
          const matchesQuery = text.includes(query);
          card.toggleAttribute("hidden", !(matchesArea && matchesQuery));
        });
      };

      areaButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeArea = button.dataset.areaFilter ?? "Todas";
          areaButtons.forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
          filterWeeks();
        });
      });

      weekSearch?.addEventListener("input", filterWeeks);
    </script>
  </body>
</html>
